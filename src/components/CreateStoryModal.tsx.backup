import React, { useState, useRef, useEffect } from 'react';
import { X, Camera, Video, Mic, Type, Upload, Play, Pause, Square, RotateCcw, FlipHorizontal, Download, ArrowLeft, Check, Clock, Users, Star, Link, ImageIcon, AlertCircle, User } from 'lucide-react';
import { storiesService } from '../services/storiesService';
import CityAutocomplete from './ui/city-autocomplete';
import { useLocation as useLocationContext } from '../contexts/LocationContext';

type PlanType = 'destaque' | 'premium' | 'basic';

interface CreateStoryModalProps {
  isOpen: boolean;
  onClose: () => void;
  companionId: string;
}

type StoryType = 'camera' | 'video' | 'audio' | 'text' | 'upload';
type ModalStep = 'plans' | 'create' | 'preview' | 'info' | 'success';

const CreateStoryModal: React.FC<CreateStoryModalProps> = ({ isOpen, onClose, companionId }) => {
  const [currentStep, setCurrentStep] = useState<ModalStep>('create');
  const [selectedPlan, setSelectedPlan] = useState<PlanType>('destaque');
  const [storyType, setStoryType] = useState<StoryType>('camera');
  const [file, setFile] = useState<File | null>(null);
  const [preview, setPreview] = useState<string | null>(null);
  const [text, setText] = useState('');
  const [textColor, setTextColor] = useState('#FFFFFF');
  const [backgroundColor, setBackgroundColor] = useState('#E91E63');
  const [isRecording, setIsRecording] = useState(false);
  const [recordingTime, setRecordingTime] = useState(0);
  const [isPlaying, setIsPlaying] = useState(false);
  const [isUploading, setIsUploading] = useState(false);
  const [cameraStream, setCameraStream] = useState<MediaStream | null>(null);
  const [facingMode, setFacingMode] = useState<'user' | 'environment'>('user');
  const [isVideoRecording, setIsVideoRecording] = useState(false);
  const [companionName, setCompanionName] = useState('');
  const [companionWhatsapp, setCompanionWhatsapp] = useState('');
  const [companionCity, setCompanionCity] = useState('');
  const [uploadSuccess, setUploadSuccess] = useState(false);
  const [linkUrl, setLinkUrl] = useState('');
  const [linkTitle, setLinkTitle] = useState('');
  const [linkDescription, setLinkDescription] = useState('');
  const [storyLinkUrl, setStoryLinkUrl] = useState('');
  const [storyLinkText, setStoryLinkText] = useState('');
  const [linkType, setLinkType] = useState<'whatsapp' | 'custom'>('whatsapp');
  // Adicionar estado para controle de carregamento
  const [isVideoLoading, setIsVideoLoading] = useState(false);
  const [videoError, setVideoError] = useState<string | null>(null);
  const videoRef = useRef<HTMLVideoElement>(null);

  const fileInputRef = useRef<HTMLInputElement>(null);
  const audioRef = useRef<HTMLAudioElement>(null);
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const timerRef = useRef<NodeJS.Timeout | null>(null);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const cameraVideoRef = useRef<HTMLVideoElement>(null);
  const modalRef = useRef<HTMLDivElement>(null);

  const storyTypes = [
    { type: 'camera' as StoryType, icon: <Camera className="w-6 h-6" />, label: 'Foto' },
    { type: 'video' as StoryType, icon: <Video className="w-6 h-6" />, label: 'Vídeo' },
    { type: 'audio' as StoryType, icon: <Mic className="w-6 h-6" />, label: 'Áudio' },
    { type: 'text' as StoryType, icon: <Type className="w-6 h-6" />, label: 'Texto' },
    // { type: 'link' as StoryType, icon: <Link className="w-6 h-6" />, label: 'Link' }, // Temporariamente desabilitado
    { type: 'upload' as StoryType, icon: <ImageIcon className="w-6 h-6" />, label: 'Galeria' },
  ];

  const backgroundColors = [
    '#E91E63', '#9C27B0', '#673AB7', '#3F51B5', 
    '#2196F3', '#00BCD4', '#009688', '#4CAF50',
    '#FF9800', '#FF5722', '#795548', '#607D8B'
  ];

  const textColors = ['#FFFFFF', '#000000', '#FFD700', '#FF4081', '#00E676'];

  const plans = [
    {
      id: 'basico',
      name: 'Básico',
      price: 29.90,
      duration: '7 dias',
      features: [
        'Story ativo por 7 dias',
        'Destaque no perfil',
        'Estatísticas básicas'
      ],
      popular: false
    },
    {
      id: 'destaque',
      name: 'Destaque',
      price: 49.90,
      duration: '7 dias',
      features: [
        'Story ativo por 7 dias',
        'Destaque PREMIUM',
        'Aparece primeiro na lista',
        'Estatísticas avançadas',
        'Badge especial'
      ],
      popular: true
    },
    {
      id: 'premium',
      name: 'Premium',
      price: 79.90,
      duration: '15 dias',
      features: [
        'Story ativo por 15 dias',
        'Destaque PREMIUM+',
        'Prioridade máxima',
        'Estatísticas completas',
        'Badge dourado',
        'Suporte VIP'
      ],
      popular: false
    }
  ];

  const locationCtx = useLocationContext();

  // Inicializar câmera quando estiver na etapa de criação
  useEffect(() => {
    if (isOpen && (storyType === 'camera' || storyType === 'video')) {
      startCamera();
    } else {
      stopCamera();
    }

    return () => stopCamera();
  }, [isOpen, storyType]);

  // useEffect para mudança de câmera
  useEffect(() => {
    if (isOpen && (storyType === 'camera' || storyType === 'video')) {
      startCamera();
    }
  }, [facingMode]);

  // useEffect para resetar modal
  useEffect(() => {
      if (!isOpen) {
        resetModal();
      }
  }, [isOpen]);

  useEffect(() => {
    if (isOpen && modalRef.current) {
      modalRef.current.scrollTo({ top: 0, behavior: 'smooth' });
    }
  }, [isOpen, currentStep]);

  const startCamera = async () => {
    try {
      // Parar stream anterior se existir
      if (cameraStream) {
        cameraStream.getTracks().forEach(track => track.stop());
      }

      const constraints = {
        video: {
          facingMode
        },
        audio: storyType === 'video'
      };

      const stream = await navigator.mediaDevices.getUserMedia(constraints);
      setCameraStream(stream);
      
      if (cameraVideoRef.current) {
        cameraVideoRef.current.srcObject = stream;
        cameraVideoRef.current.play().catch(console.error);
      }
    } catch (error) {
      console.error('Erro ao acessar câmera:', error);
      alert('Erro ao acessar a câmera. Verifique as permissões.');
    }
  };

  const stopCamera = () => {
    if (cameraStream) {
      cameraStream.getTracks().forEach(track => {
        track.stop();
        cameraStream.removeTrack(track);
      });
      setCameraStream(null);
      
      if (cameraVideoRef.current) {
        cameraVideoRef.current.srcObject = null;
      }
    }
  };

  const switchCamera = () => {
    setFacingMode(prev => prev === 'user' ? 'environment' : 'user');
  };

  const capturePhoto = () => {
    if (!cameraVideoRef.current || !canvasRef.current) return;

    const video = cameraVideoRef.current;
    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d')!;

    // Configurar canvas com dimensões do vídeo
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;

    // Desenhar frame atual do vídeo no canvas
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

    // Converter para blob e criar arquivo
    canvas.toBlob((blob) => {
      if (blob) {
        const photoFile = new File([blob], `photo_${Date.now()}.jpg`, {
          type: 'image/jpeg'
        });
        setFile(photoFile);
        setPreview(URL.createObjectURL(blob));
        stopCamera(); // Parar câmera após capturar
        setCurrentStep('preview'); // Ir para tela de preview (igual vídeo)
      }
    }, 'image/jpeg', 0.9);
  };

  const startVideoRecording = async () => {
    try {
      // Resetar estados
      setVideoError(null);
      setIsVideoLoading(false);
      console.log('Iniciando gravação...');

      // Usar configurações mais flexíveis para vídeo
      const mediaConstraints = {
        video: {
          facingMode, // Remover exact para maior compatibilidade
          width: { ideal: 1080 },
          height: { ideal: 1920 },
          aspectRatio: { ideal: 9/16 }
        },
        audio: {
          echoCancellation: true,
          noiseSuppression: true,
          autoGainControl: true
        }
      };

      // Reutilizar stream existente se possível
      let stream = cameraStream;
      
      // Só criar novo stream se necessário
      if (!stream || !stream.active || stream.getVideoTracks().length === 0) {
        // Parar stream anterior se existir
        if (stream) {
          stream.getTracks().forEach(track => track.stop());
        }
        
        stream = await navigator.mediaDevices.getUserMedia(mediaConstraints);
        setCameraStream(stream);
      }
      
      // Adicionar áudio se necessário
      if (stream.getAudioTracks().length === 0) {
        const audioStream = await navigator.mediaDevices.getUserMedia({ audio: mediaConstraints.audio });
        audioStream.getAudioTracks().forEach(track => stream.addTrack(track));
      }
      
      if (cameraVideoRef.current) {
        cameraVideoRef.current.srcObject = stream;
        await cameraVideoRef.current.play();
      }

      // Tentar diferentes formatos para compatibilidade
      let mimeType = 'video/webm;codecs=vp9';
      if (!MediaRecorder.isTypeSupported(mimeType)) {
        mimeType = 'video/webm;codecs=vp8';
        if (!MediaRecorder.isTypeSupported(mimeType)) {
          mimeType = 'video/webm';
          if (!MediaRecorder.isTypeSupported(mimeType)) {
            mimeType = 'video/mp4';
            if (!MediaRecorder.isTypeSupported(mimeType)) {
              mimeType = '';
            }
          }
        }
      }
      
      console.log('🎬 Usando formato:', mimeType);

      const mediaRecorder = new MediaRecorder(stream, 
        mimeType ? { mimeType } : undefined
      );

      const chunks: BlobPart[] = [];

      mediaRecorder.ondataavailable = (event) => {
        if (event.data.size > 0) {
          chunks.push(event.data);
          console.log('Chunk de dados recebido:', event.data.size, 'bytes');
        }
      };

      mediaRecorder.onstart = () => {
        console.log('MediaRecorder iniciou gravação');
        setIsVideoRecording(true);
        setRecordingTime(0);
      };

      mediaRecorder.onerror = (error) => {
        console.error('Erro no MediaRecorder:', error);
        setVideoError('Erro na gravação. Tente novamente.');
        stopVideoRecording();
      };

      mediaRecorder.onstop = () => {
        console.log('🎬 Gravação finalizada, processando...');
        
        if (chunks.length === 0) {
          console.error('Nenhum dado gravado!');
          setVideoError('Erro na gravação. Nenhum dado capturado.');
          return;
        }

        try {
          const blob = new Blob(chunks, { type: 'video/mp4' });
          console.log('Blob criado:', blob.size, 'bytes');
          
          if (blob.size === 0) {
            throw new Error('Blob vazio');
          }

          const videoFile = new File([blob], `video_${Date.now()}.mp4`, {
            type: 'video/mp4'
          });
          
          const previewUrl = URL.createObjectURL(blob);
        setFile(videoFile);
          setPreview(previewUrl);
          setCurrentStep('preview');
          console.log('✅ Preview criado com sucesso');
        } catch (error) {
          console.error('Erro ao processar vídeo:', error);
          setVideoError('Erro ao processar o vídeo. Tente novamente.');
        }
      };

      mediaRecorderRef.current = mediaRecorder;
      
      // Configurar para coletar dados a cada 1 segundo
      mediaRecorder.start(1000);

      // Timer para contagem (máximo 30 segundos)
      timerRef.current = setInterval(() => {
        setRecordingTime(prev => {
          if (prev >= 29) {
            stopVideoRecording();
            return 30;
          }
          return prev + 1;
        });
      }, 1000);

      console.log('✅ Gravação iniciada com sucesso');

    } catch (error) {
      console.error('Erro ao iniciar gravação:', error);
      setVideoError('Erro ao iniciar gravação. Verifique as permissões da câmera e microfone.');
      setIsVideoRecording(false);
    }
  };

  const stopVideoRecording = () => {
    console.log('Tentando parar gravação...');
    if (mediaRecorderRef.current && mediaRecorderRef.current.state === 'recording') {
      try {
      mediaRecorderRef.current.stop();
      setIsVideoRecording(false);
      
      if (timerRef.current) {
        clearInterval(timerRef.current);
        timerRef.current = null;
        }

        // Parar todas as tracks de áudio e vídeo
        if (cameraStream) {
          cameraStream.getTracks().forEach(track => {
            track.stop();
            cameraStream.removeTrack(track);
          });
          setCameraStream(null);
        }
        
        console.log('Gravação parada com sucesso');
      } catch (error) {
        console.error('Erro ao parar gravação:', error);
        // Forçar reset do estado
        setIsVideoRecording(false);
        if (timerRef.current) {
          clearInterval(timerRef.current);
          timerRef.current = null;
        }
      }
    }
  };

  const resetModal = () => {
    setCurrentStep('plans');
    setSelectedPlan('destaque');
    setStoryType('camera');
    setFile(null);
    setPreview(null);
    setText('');
    setTextColor('#FFFFFF');
    setBackgroundColor('#E91E63');
    setIsRecording(false);
    setRecordingTime(0);
    setIsPlaying(false);
    setIsUploading(false);
    setIsVideoRecording(false);
    setCompanionName('');
    setCompanionWhatsapp('');
    setCompanionCity('');
    setUploadSuccess(false);
    setLinkUrl('');
    setLinkTitle('');
    setLinkDescription('');
    setStoryLinkUrl('');
    setStoryLinkText('');
    setLinkType('whatsapp');
    
    // Parar câmera e limpar timers
    stopCamera();
    if (timerRef.current) {
      clearInterval(timerRef.current);
      timerRef.current = null;
    }
    
    // Limpar mediaRecorder
    if (mediaRecorderRef.current) {
      mediaRecorderRef.current = null;
    }
  };

  const handleFileSelect = (event: React.ChangeEvent<HTMLInputElement>) => {
    const selectedFile = event.target.files?.[0];
    if (!selectedFile) return;

    // Validar tipo de arquivo
    if (!selectedFile.type.startsWith('image/') && !selectedFile.type.startsWith('video/')) {
      alert('Por favor, selecione uma imagem ou vídeo válido.');
      return;
    }

    // Validar tamanho (15MB para imagem, 50MB para vídeo)
    const maxSize = selectedFile.type.startsWith('image/') ? 15 * 1024 * 1024 : 50 * 1024 * 1024;
    if (selectedFile.size > maxSize) {
      alert(`Arquivo muito grande. Máximo: ${selectedFile.type.startsWith('image/') ? '15MB' : '50MB'}`);
      return;
    }

    setFile(selectedFile);
    setPreview(URL.createObjectURL(selectedFile));
    stopCamera(); // Parar câmera ao fazer upload
  };

  const startAudioRecording = async () => {
    try {
      stopCamera(); // Parar câmera para gravar áudio
      
      const stream = await navigator.mediaDevices.getUserMedia({ 
        audio: {
          echoCancellation: true,
          noiseSuppression: true,
          autoGainControl: true
        } 
      });

      const mediaRecorder = new MediaRecorder(stream, {
        mimeType: 'audio/webm;codecs=opus'
      });

      const chunks: BlobPart[] = [];

      mediaRecorder.ondataavailable = (event) => {
        if (event.data.size > 0) {
          chunks.push(event.data);
        }
      };

      mediaRecorder.onstop = () => {
        const blob = new Blob(chunks, { type: 'audio/webm;codecs=opus' });
        const audioFile = new File([blob], `audio_${Date.now()}.webm`, {
          type: 'audio/webm;codecs=opus'
        });
        
        setFile(audioFile);
        setPreview(URL.createObjectURL(blob));
        
        // Parar todas as tracks
        stream.getTracks().forEach(track => track.stop());
      };

      mediaRecorderRef.current = mediaRecorder;
      mediaRecorder.start();
      setIsRecording(true);
      setRecordingTime(0);

      // Timer para contagem (máximo 30 segundos)
      timerRef.current = setInterval(() => {
        setRecordingTime(prev => {
          if (prev >= 29) {
            stopAudioRecording();
            return 30;
          }
          return prev + 1;
        });
      }, 1000);

    } catch (error) {
      console.error('Erro ao acessar microfone:', error);
      alert('Erro ao acessar o microfone. Verifique as permissões.');
    }
  };

  const stopAudioRecording = () => {
    if (mediaRecorderRef.current && isRecording) {
      mediaRecorderRef.current.stop();
      setIsRecording(false);
      
      if (timerRef.current) {
        clearInterval(timerRef.current);
        timerRef.current = null;
      }
    }
  };

  const playAudio = () => {
    if (audioRef.current) {
      audioRef.current.play();
      setIsPlaying(true);
    }
  };

  const pauseAudio = () => {
    if (audioRef.current) {
      audioRef.current.pause();
      setIsPlaying(false);
    }
  };

  const generateTextImage = (): Promise<File> => {
    return new Promise((resolve) => {
      const canvas = canvasRef.current!;
      const ctx = canvas.getContext('2d')!;
      
      // Configurar canvas (9:16 aspect ratio para stories)
      canvas.width = 480;
      canvas.height = 854;
      
      // Fundo
      ctx.fillStyle = backgroundColor;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      // Configurar texto
      ctx.fillStyle = textColor;
      ctx.font = 'bold 32px Arial, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      // Quebrar texto em linhas
      const words = text.split(' ');
      const lines = [];
      let currentLine = '';
      
      for (const word of words) {
        const testLine = currentLine + (currentLine ? ' ' : '') + word;
        const metrics = ctx.measureText(testLine);
        
        if (metrics.width > canvas.width - 60 && currentLine !== '') {
          lines.push(currentLine);
          currentLine = word;
        } else {
          currentLine = testLine;
        }
      }
      lines.push(currentLine);
      
      // Desenhar linhas centralizadas
      const lineHeight = 40;
      const totalHeight = lines.length * lineHeight;
      const startY = (canvas.height - totalHeight) / 2 + lineHeight / 2;
      
      lines.forEach((line, index) => {
        ctx.fillText(line, canvas.width / 2, startY + (index * lineHeight));
      });
      
      // Converter para arquivo
      canvas.toBlob((blob) => {
        if (blob) {
          const textFile = new File([blob], `text_story_${Date.now()}.png`, {
            type: 'image/png'
          });
          resolve(textFile);
        }
      }, 'image/png');
    });
  };

  const generateLinkImage = (): Promise<File> => {
    return new Promise((resolve) => {
      const canvas = canvasRef.current!;
      const ctx = canvas.getContext('2d')!;
      
      // Configurar canvas (9:16 aspect ratio para stories)
      canvas.width = 480;
      canvas.height = 854;
      
      // Fundo gradiente
      const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
      gradient.addColorStop(0, '#667eea');
      gradient.addColorStop(1, '#764ba2');
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      // Ícone de link
      ctx.fillStyle = 'white';
      ctx.font = 'bold 60px Arial, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('🔗', canvas.width / 2, 150);
      
      // Título
      if (linkTitle) {
        ctx.fillStyle = 'white';
        ctx.font = 'bold 28px Arial, sans-serif';
        ctx.textAlign = 'center';
        
        // Quebrar título em linhas
        const titleWords = linkTitle.split(' ');
        const titleLines = [];
        let currentTitleLine = '';
        
        for (const word of titleWords) {
          const testLine = currentTitleLine + (currentTitleLine ? ' ' : '') + word;
          const metrics = ctx.measureText(testLine);
          
          if (metrics.width > canvas.width - 80 && currentTitleLine !== '') {
            titleLines.push(currentTitleLine);
            currentTitleLine = word;
          } else {
            currentTitleLine = testLine;
          }
        }
        titleLines.push(currentTitleLine);
        
        titleLines.forEach((line, index) => {
          ctx.fillText(line, canvas.width / 2, 250 + (index * 35));
        });
      }
      
      // Descrição
      if (linkDescription) {
        ctx.fillStyle = 'rgba(255, 255, 255, 0.9)';
        ctx.font = '20px Arial, sans-serif';
        ctx.textAlign = 'center';
        
        // Quebrar descrição em linhas
        const descWords = linkDescription.split(' ');
        const descLines = [];
        let currentDescLine = '';
        
        for (const word of descWords) {
          const testLine = currentDescLine + (currentDescLine ? ' ' : '') + word;
          const metrics = ctx.measureText(testLine);
          
          if (metrics.width > canvas.width - 80 && currentDescLine !== '') {
            descLines.push(currentDescLine);
            currentDescLine = word;
          } else {
            currentDescLine = testLine;
          }
        }
        descLines.push(currentDescLine);
        
        descLines.forEach((line, index) => {
          ctx.fillText(line, canvas.width / 2, 400 + (index * 25));
        });
      }
      
      // URL
      ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
      ctx.font = '16px Arial, sans-serif';
      ctx.textAlign = 'center';
      
      // Encurtar URL se muito longa
      let displayUrl = linkUrl;
      if (displayUrl.length > 40) {
        displayUrl = displayUrl.substring(0, 37) + '...';
      }
      
      ctx.fillText(displayUrl, canvas.width / 2, 600);
      
      // Call to action
      ctx.fillStyle = 'white';
      ctx.font = 'bold 24px Arial, sans-serif';
      ctx.fillText('👆 Clique no link para acessar', canvas.width / 2, 700);
      
      // Converter para arquivo
      canvas.toBlob((blob) => {
        if (blob) {
          const linkFile = new File([blob], `link_story_${Date.now()}.png`, {
            type: 'image/png'
          });
          resolve(linkFile);
        }
      }, 'image/png');
    });
  };

  // Função para gerar thumbnail de vídeo
  const generateVideoThumbnail = (videoFile: File): Promise<File> => {
    return new Promise((resolve, reject) => {
      const video = document.createElement('video');
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      
      if (!ctx) {
        reject(new Error('Não foi possível criar contexto do canvas'));
        return;
      }

      video.muted = true;
      video.crossOrigin = 'anonymous';
      
      video.onloadedmetadata = () => {
        // Definir tamanho do canvas baseado no vídeo (máximo 500x500 para thumbnail)
        const maxSize = 500;
        let { videoWidth, videoHeight } = video;
        
        if (videoWidth > videoHeight) {
          if (videoWidth > maxSize) {
            videoHeight = (videoHeight * maxSize) / videoWidth;
            videoWidth = maxSize;
          }
        } else {
          if (videoHeight > maxSize) {
            videoWidth = (videoWidth * maxSize) / videoHeight;
            videoHeight = maxSize;
          }
        }
        
        canvas.width = videoWidth;
        canvas.height = videoHeight;
        
        // Ir para o primeiro segundo do vídeo para capturar uma boa imagem
        video.currentTime = Math.min(1, video.duration / 2);
      };
      
      video.onseeked = () => {
        try {
          // Desenhar o frame do vídeo no canvas
          ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
          
          // Converter canvas para blob com qualidade reduzida para thumbnail
          canvas.toBlob((blob) => {
            if (blob) {
              const thumbnailFile = new File([blob], `thumbnail_${Date.now()}.jpg`, { 
                type: 'image/jpeg' 
              });
              console.log('✅ Thumbnail gerada:', thumbnailFile.name, thumbnailFile.size);
              resolve(thumbnailFile);
            } else {
              reject(new Error('Falha ao gerar thumbnail'));
            }
          }, 'image/jpeg', 0.7); // Reduzir qualidade para 70%
        } catch (error) {
          reject(error);
        }
      };
      
      video.onerror = () => {
        reject(new Error('Erro ao carregar vídeo para thumbnail'));
      };
      
      // Criar URL do vídeo e carregar
      const videoUrl = URL.createObjectURL(videoFile);
      video.src = videoUrl;
      video.load();
    });
  };

  const handleUpload = async () => {
    try {
      setIsUploading(true);

      // Validar campos obrigatórios
      if (!companionName || !companionWhatsapp || !companionCity || !file) {
        throw new Error('Por favor, preencha todos os campos obrigatórios');
      }

      let imageUrl;
      let thumbnailUrl = null;

      // Upload do arquivo principal
      if (storyType === 'video') {
        // Para vídeos, usar uploadVideo
        imageUrl = await storiesService.uploadVideo(file, companionId);
        
        // Gerar e fazer upload da thumbnail
        const thumbnailFile = await generateVideoThumbnail(file);
        thumbnailUrl = await storiesService.uploadImage(thumbnailFile, companionId);
      } else {
        // Para outros tipos, usar uploadImage
        imageUrl = await storiesService.uploadImage(file, companionId);
      }

      // Determinar o tipo de story a ser salvo
      const storyTypeToSave = storyType === 'camera' ? 'photo' : storyType;

      // Preparar dados do story
      const storyData = {
        companionId,
        requesterName: companionName,
        requesterWhatsapp: companionWhatsapp,
        type: storyTypeToSave as 'photo' | 'video' | 'audio' | 'text',
        url: imageUrl,
        thumbnail: thumbnailUrl,
        duration: recordingTime > 0 ? recordingTime : undefined,
        file_size: file.size,
        mime_type: file.type,
        plan_type: 'destaque' as const,
        plan_name: 'Destaque',
        plan_price: 0,
        story_link_url: companionWhatsapp,
        story_link_text: storyLinkText || 'Chamar no WhatsApp',
        link_type: 'whatsapp',
        // Adicionar cidade - garantir que seja salva corretamente
        companion_city: companionCity
      };

      console.log('🏗️ CreateStoryModal - Dados do story antes de salvar:', {
        companionName,
        companionCity,
        storyData
      });

      // Salvar story no banco
      await storiesService.saveCreatedStory(storyData);
      
        setUploadSuccess(true);
        setCurrentStep('success');
      } catch (error) {
      console.error('Erro ao fazer upload:', error);
      alert('Erro ao enviar o story. Por favor, tente novamente.');
    } finally {
      setIsUploading(false);
    }
  };

  // Função para aceitar o vídeo gravado
  const handleAcceptVideo = () => {
    console.log('✅ Vídeo aceito, indo para informações...');
    stopCamera(); // Agora sim parar a câmera
    setCurrentStep('info');
  };

  // Função para rejeitar e gravar novamente
  const handleRetakeVideo = () => {
    console.log('🔄 Gravando vídeo novamente...');
    setFile(null);
    setPreview(null);
    setRecordingTime(0);
    // Voltar para tela de criação para gravar novamente
    setCurrentStep('create');
  };

  if (!isOpen) return null;

  // Renderizar mensagem de período gratuito
  if (currentStep === 'plans') {
    return (
      <div className="fixed inset-0 bg-black bg-opacity-80 backdrop-blur-sm flex items-center justify-center z-50 p-4">
        <div className="bg-pink-200 p-8 rounded-3xl max-w-sm w-full mx-4 text-center shadow-2xl relative" style={{ fontFamily: "'Poppins', sans-serif", fontWeight: 300 }}>
          
          {/* Conteúdo */}
          <div className="space-y-6">
            {/* Título */}
            <h2 className="text-2xl font-light text-gray-900">Criar um Story</h2>
            
            {/* Subtítulo */}
            <p className="text-gray-800 leading-relaxed font-light">
              Destaque seu perfil com um novo story
            </p>

            {/* Lista de benefícios minimalista */}
            <div className="space-y-4 text-left">
              <div className="flex items-center space-x-3">
                <span className="text-gray-900 font-normal">✓</span>
                <span className="text-gray-900 font-light">100% gratuito</span>
              </div>
              <div className="flex items-center space-x-3">
                <span className="text-gray-900 font-normal">✓</span>
                <span className="text-gray-900 font-light">Visível por 7 dias</span>
              </div>
              <div className="flex items-center space-x-3">
                <span className="text-gray-900 font-normal">✓</span>
                <span className="text-gray-900 font-light">Inclui um botão de contato</span>
              </div>
            </div>

            {/* Botão principal */}
            <button 
              onClick={() => setCurrentStep('create')} 
              className="bg-gradient-to-r from-pink-300 to-pink-500 text-white px-8 py-3 rounded-full font-semibold hover:from-pink-400 hover:to-pink-600 transition-all w-full"
            >
              Criar Story Grátis
            </button>

            {/* Botão voltar */}
            <button
              onClick={onClose}
              className="text-gray-800 hover:text-gray-900 transition-colors text-sm font-light flex items-center justify-center space-x-2"
            >
              <span>←</span>
              <span>Voltar</span>
            </button>
          </div>

          {/* Botão X no canto */}
          <button
            onClick={onClose}
            className="absolute top-4 right-4 w-8 h-8 bg-white hover:bg-gray-100 rounded-full flex items-center justify-center transition-colors"
          >
            <X className="w-4 h-4 text-gray-500" />
          </button>
        </div>
      </div>
    );
  }


  // Renderizar tela de preview de foto ou vídeo
  if (currentStep === 'preview') {
    return (
      <div className="fixed inset-0 bg-black bg-opacity-95 flex items-center justify-center z-50">
        <div className="relative w-full h-full max-w-md mx-auto bg-black flex flex-col">
          {/* Header */}
          <div className="flex justify-between items-center p-4 text-white bg-black/50 backdrop-blur-sm">
            <button onClick={() => setCurrentStep('create')} className="hover:text-gray-300 transition-colors">
              <ArrowLeft className="w-6 h-6" />
            </button>
            <h2 className="text-lg font-bold">Preview</h2>
            <button onClick={onClose} className="hover:text-gray-300 transition-colors">
              <X className="w-6 h-6" />
            </button>
          </div>

          {/* Preview da foto ou vídeo */}
          <div className="flex-1 flex items-center justify-center p-4">
            {preview && file && file.type.startsWith('image/') ? (
              <img src={preview} alt="Preview da foto" className="w-full h-full object-contain rounded-lg" style={{ maxWidth: '100%', maxHeight: '100%' }} />
            ) : preview && file && file.type.startsWith('video/') ? (
              <video
                ref={videoRef}
                key={preview}
                src={preview}
                className="w-full h-full object-contain rounded-lg"
                controls
                playsInline
                style={{ maxWidth: '100%', maxHeight: '100%' }}
              />
            ) : (
              <div className="text-center text-white">
                <div className="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4">
                  <Video className="w-8 h-8" />
                </div>
                <p className="text-sm">Processando mídia...</p>
              </div>
            )}
          </div>

          {/* Botões de ação */}
          <div className="p-6 space-y-3 bg-black/50 backdrop-blur-sm">
            <button
              onClick={() => setCurrentStep('info')}
              className="w-full py-4 bg-gradient-to-r from-green-500 to-green-600 text-white rounded-xl font-bold text-lg transition-all transform hover:scale-105 shadow-lg flex items-center justify-center space-x-2"
            >
              <Check className="w-6 h-6" />
              <span>Usar esta mídia</span>
            </button>
            <button
              onClick={() => setCurrentStep('create')}
              className="w-full py-4 bg-gradient-to-r from-velvet-pink-500 to-velvet-pink-600 text-white rounded-xl font-bold text-lg transition-all transform hover:scale-105 shadow-lg flex items-center justify-center space-x-2"
            >
              <RotateCcw className="w-6 h-6" />
              <span>Refazer</span>
            </button>
          </div>
        </div>
      </div>
    );
  }

  // Renderizar modal de sucesso PRIMEIRO (prioridade máxima)
  if (currentStep === 'success') {
    console.log('🎉 Renderizando tela de sucesso!');
    console.log('📊 uploadSuccess:', uploadSuccess);
    console.log('📊 selectedPlan:', selectedPlan);
    return (
      <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4" onClick={(e) => e.stopPropagation()}>
        <div className="relative w-full max-w-md mx-auto bg-white rounded-2xl shadow-2xl flex flex-col max-h-[90vh]" style={{ fontFamily: "'Poppins', sans-serif" }} onClick={(e) => e.stopPropagation()}>
          {/* Header */}
          <div className="flex justify-between items-center p-6 border-b border-gray-100">
            <div className="w-6"></div>
            <h2 className="text-xl font-bold text-gray-900">Story Enviado!</h2>
            <button onClick={onClose} className="text-gray-500 hover:text-gray-700 transition-colors">
              <X className="w-6 h-6" />
            </button>
          </div>

          {/* Conteúdo com scroll */}
          <div className="p-6 flex-1 overflow-y-auto">
            <div className="text-center mb-6">
              {/* Ícone de sucesso */}
              <div className="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <Check className="w-12 h-12 text-green-600" />
              </div>

              {/* Título */}
              <h3 className="text-2xl font-bold mb-2 text-gray-900">
                Story Criado com Sucesso! 🎉
              </h3>
              <p className="text-gray-600 text-sm">
                Seu story gratuito foi enviado e está sendo analisado
              </p>
            </div>

            {/* Informações importantes */}
            <div className="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
              <div className="text-center mb-3">
                <div className="text-2xl mb-2">ℹ️</div>
                <h4 className="font-bold text-blue-900 text-lg">Informações Importantes</h4>
              </div>
              
              <div className="text-blue-800 space-y-3">
                <div className="bg-white rounded-lg p-3 border border-blue-100">
                  <p className="font-medium text-center mb-2">📱 Story Gratuito</p>
                  <p className="text-sm text-center">
                    Seu story foi enviado gratuitamente e passará por análise antes de ser publicado
                  </p>
                </div>
              </div>
            </div>

            {/* Próximos passos */}
            <div className="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-6">
              <h4 className="font-bold mb-3 text-center text-gray-900">📱 Próximos Passos</h4>
              
              <div className="space-y-4">
                <div className="flex items-start space-x-3">
                  <div className="w-8 h-8 bg-pink-400 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span className="text-xs font-bold text-white">1</span>
                  </div>
                  <div className="text-gray-800">
                    <p className="font-semibold">Análise do Conteúdo</p>
                    <p className="text-sm text-gray-600">Nosso admin analisará seu story em até 24 horas</p>
                  </div>
                </div>
                
                <div className="flex items-start space-x-3">
                  <div className="w-8 h-8 bg-pink-400 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span className="text-xs font-bold text-white">2</span>
                  </div>
                  <div className="text-gray-800">
                    <p className="font-semibold">Publicação</p>
                    <p className="text-sm text-gray-600">
                      Após aprovação, seu story será publicado gratuitamente
                    </p>
                  </div>
                </div>
                
              </div>
            </div>

            {/* Dicas */}
            <div className="bg-green-50 border border-green-200 rounded-xl p-4">
              <h4 className="font-bold mb-2 text-center text-green-900">💡 Dicas para Aprovação</h4>
              <ul className="text-sm text-green-800 space-y-2">
                <li className="flex items-start space-x-2">
                  <span className="text-green-600 mt-0.5">✓</span>
                  <span>Use fotos e vídeos de boa qualidade e bem iluminados</span>
                </li>
                <li className="flex items-start space-x-2">
                  <span className="text-green-600 mt-0.5">✓</span>
                  <span>Evite conteúdo explícito demais nas imagens principais</span>
                </li>
                <li className="flex items-start space-x-2">
                  <span className="text-green-600 mt-0.5">✓</span>
                  <span>Seja natural e autêntica nas suas fotos</span>
                </li>
                <li className="flex items-start space-x-2">
                  <span className="text-green-600 mt-0.5">✓</span>
                  <span>Preencha todas as informações corretamente</span>
                </li>
              </ul>
            </div>

          </div>

            {/* Botões integrados no conteúdo */}
            <div className="space-y-3 mt-6">
              {/* Opção para criar outro story */}
                <button
                onClick={() => {
                  console.log('🔄 Usuário quer criar outro story');
                  // Resetar o modal e voltar para seleção de planos
                  resetModal();
                  setTimeout(() => {
                    setCurrentStep('create');
                  }, 100);
                }}
                className="w-full py-4 bg-gradient-to-r from-pink-400 to-pink-500 text-white rounded-xl font-bold text-lg hover:from-pink-500 hover:to-pink-600 transition-all transform hover:scale-105 shadow-lg"
              >
                🎬 Criar Outro Story
                </button>
                
              {/* Botão para finalizar */}
                <button
                onClick={() => {
                  console.log('✅ Usuário finalizou o processo');
                  resetModal();
                  onClose();
                }}
                className="w-full py-4 bg-gray-100 text-gray-700 rounded-xl font-bold text-lg hover:bg-gray-200 transition-colors border border-gray-200"
              >
                Fechar
                </button>
            </div>
          </div>
        </div>
      </div>
    );
  }

  // Renderizar modal de informações
  if (currentStep === 'info') {
    return (
      <div className="fixed inset-0 bg-black bg-opacity-80 backdrop-blur-sm flex items-center justify-center z-50 p-4">
        <div className="bg-white rounded-3xl max-w-md w-full mx-4 shadow-2xl relative" style={{ fontFamily: "'Poppins', sans-serif" }}>
          {/* Header */}
          <div className="flex justify-between items-center p-6 border-b border-gray-100">
            <button onClick={() => setCurrentStep('preview')} className="text-gray-600 hover:text-gray-800 transition-colors">
              <ArrowLeft className="w-6 h-6" />
            </button>
            <h2 className="text-lg font-bold text-gray-900">Informações do Story</h2>
            <button onClick={onClose} className="text-gray-600 hover:text-gray-800 transition-colors">
              <X className="w-6 h-6" />
            </button>
          </div>

          {/* Conteúdo */}
          <div className="p-6">
            <div className="text-center mb-8">
              {/* Título */}
              <h3 className="text-2xl font-bold text-gray-900 mb-2">
                Informações do Story
              </h3>
              <p className="text-gray-600 text-sm">
                ✨ Quase lá! Preencha com seus dados:
              </p>
            </div>

            {/* Formulário */}
            <div className="space-y-6">
              {/* Nome */}
              <div>
                <label className="block text-gray-900 font-medium mb-2 text-sm">
                  Nome
                </label>
                <input
                  type="text"
                  value={companionName}
                  onChange={(e) => setCompanionName(e.target.value)}
                  placeholder="Digite seu nome"
                  className="w-full px-4 py-3 rounded-xl bg-white border border-gray-200 text-gray-900 placeholder-gray-400 focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-100 text-sm font-sans"
                  required
                />
                <p className="text-gray-500 text-xs mt-1">
                  Como será exibido no story
                </p>
              </div>

              {/* WhatsApp */}
              <div>
                <label className="block text-gray-900 font-medium mb-2 text-sm">
                  WhatsApp
                </label>
                <div className="flex">
                  <span className="inline-flex items-center px-3 rounded-l-xl border border-r-0 border-gray-200 bg-gray-50 text-gray-600 text-sm">
                    +55
                  </span>
                  <input
                    type="tel"
                    value={companionWhatsapp}
                    onChange={(e) => setCompanionWhatsapp(e.target.value)}
                    placeholder="Digite seu número"
                    className="flex-1 rounded-r-xl border border-gray-200 px-4 py-3 text-gray-900 placeholder-gray-400 focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-100 text-sm font-sans"
                  />
                </div>
                <p className="text-gray-500 text-xs mt-1">
                  Usado para contato e como botão no seu story
                </p>
              </div>

              {/* Cidade */}
              <div>
                <label className="block text-gray-900 font-medium mb-2 text-sm">
                  Cidade
                </label>
                <CityAutocomplete
                  value={companionCity}
                  onChange={setCompanionCity}
                  placeholder="Digite sua cidade"
                  className="w-full px-4 py-3 rounded-xl bg-white border border-gray-200 text-gray-900 placeholder-gray-400 focus:border-pink-400 focus:outline-none focus:ring-2 focus:ring-pink-100 text-sm font-sans !text-gray-900 !placeholder-gray-400"
                />
                <p className="text-gray-500 text-xs mt-1">
                  Onde você atua
                </p>
              </div>

            </div>

            {/* Botões */}
            <div className="mt-8 space-y-4">
              {isUploading ? (
                <div className="w-full py-4 bg-gray-300 text-gray-700 rounded-full text-center">
                  <div className="flex items-center justify-center space-x-2">
                    <div className="animate-spin rounded-full h-5 w-5 border-b-2 border-gray-700"></div>
                    <span>Enviando story...</span>
                  </div>
                </div>
              ) : (
                <button
                  onClick={handleUpload}
                  disabled={!companionName || !companionWhatsapp || !companionCity}
                  className="w-full py-3 bg-pink-100 text-pink-700 rounded-full font-bold text-sm transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                  style={{ backgroundColor: '#fcd3df', color: '#d63384' }}
                >
                  🚀 Enviar Story
                </button>
              )}
              
              <button
                onClick={() => setCurrentStep('preview')}
                className="w-full text-center text-gray-600 hover:text-gray-800 transition-colors text-sm font-light"
              >
                ← Voltar
              </button>
            </div>
          </div>
        </div>
      </div>
    );
  }

  // Renderizar etapa de criação
  return (
    <div className="fixed inset-0 bg-black bg-opacity-90 flex items-center justify-center z-50">
      <div className="relative w-full h-full max-w-md mx-auto bg-black flex flex-col">
        {/* Header */}
        <div className="absolute top-0 left-0 right-0 z-20 flex justify-between items-center p-4">
          <button
            onClick={() => setCurrentStep('plans')}
            className="text-white hover:text-gray-300 transition-colors"
          >
            <ArrowLeft className="w-6 h-6" />
          </button>
          
          <button
            onClick={onClose}
            className="text-white hover:text-gray-300 transition-colors"
          >
            <X className="w-6 h-6" />
          </button>
          
          {/* Timer para gravação */}
          {(isRecording || isVideoRecording) && (
            <div className="bg-red-500 text-white px-3 py-1 rounded-full text-sm font-bold">
              {Math.floor(recordingTime / 60)}:{(recordingTime % 60).toString().padStart(2, '0')}
            </div>
          )}
        </div>

        {/* Área principal */}
        <div className="flex-1 relative overflow-hidden">
          {/* Câmera ativa */}
          {storyType === 'camera' || storyType === 'video' ? (
            !preview ? (
              <div className="w-full h-full relative">
                <video
                  ref={cameraVideoRef}
                  autoPlay
                  playsInline
                  muted
                  className={`w-full h-full object-cover ${facingMode === 'user' ? 'transform -scale-x-100' : ''}`}
                  style={{ transform: facingMode === 'user' ? 'scaleX(-1)' : 'none' }}
                />
                
                {/* Controles da câmera */}
                <div className="absolute bottom-20 left-0 right-0 flex flex-col items-center">
                  {/* Contador de tempo */}
                  {isVideoRecording && (
                    <div className="mb-4 px-4 py-2 bg-black/50 rounded-full text-white text-lg">
                      {recordingTime}s
                    </div>
                  )}
                  
                  {/* Botões */}
                  <div className="flex justify-center items-center space-x-8">
                  {/* Botão alternar câmera */}
                  <button
                    onClick={switchCamera}
                    className="p-3 bg-black/50 rounded-full text-white hover:bg-black/70 transition-colors"
                      title="Alternar câmera"
                  >
                    <FlipHorizontal className="w-6 h-6" />
                  </button>

                  {/* Botão capturar/gravar */}
                  <button
                    onClick={storyType === 'camera' ? capturePhoto : (isVideoRecording ? stopVideoRecording : startVideoRecording)}
                      className={`relative flex items-center justify-center transition-all ${
                      storyType === 'camera' 
                          ? 'bg-white hover:bg-gray-200 w-16 h-16 rounded-full'
                        : isVideoRecording 
                            ? 'bg-red-500 hover:bg-red-600 w-12 h-12 rounded-lg'
                            : 'bg-red-500 hover:bg-red-600 w-16 h-16 rounded-full'
                    }`}
                      title={storyType === 'camera' ? 'Tirar foto' : (isVideoRecording ? 'Parar gravação' : 'Iniciar gravação')}
                  >
                    {storyType === 'camera' ? (
                      <Camera className="w-8 h-8 text-black" />
                    ) : isVideoRecording ? (
                        <Square className="w-6 h-6 text-white" />
                    ) : (
                      <Video className="w-8 h-8 text-white" />
                    )}
                      
                      {/* Indicador de gravação */}
                      {isVideoRecording && (
                        <div className="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-red-500 animate-pulse" />
                      )}
                  </button>

                  {/* Placeholder para simetria */}
                  <div className="p-3 w-12 h-12"></div>
                </div>
                </div>

                {/* Dicas de uso */}
                {storyType === 'video' && !isVideoRecording && !preview && (
                  <div className="absolute top-4 left-1/2 transform -translate-x-1/2 bg-black/50 px-4 py-2 rounded-full text-white text-sm">
                    Toque no botão para começar a gravar
                  </div>
                )}
                
                {isVideoRecording && (
                  <div className="absolute top-4 left-1/2 transform -translate-x-1/2 bg-black/50 px-4 py-2 rounded-full text-white text-sm">
                    Toque novamente para parar
                  </div>
                )}
              </div>
            ) : (
              <div className="w-full h-full relative">
                {file?.type.startsWith('video/') ? (
                  <video
                    ref={videoRef}
                    src={preview}
                    controls
                    className="w-full h-full object-cover"
                  />
                ) : (
                  <img
                    src={preview}
                    alt="Preview"
                    className="w-full h-full object-cover"
                  />
                )}
              </div>
            )
          ) : storyType === 'audio' ? (
            <div className="w-full h-full bg-gradient-to-br from-purple-500 to-pink-500 flex flex-col items-center justify-center p-8">
              <div className="text-center text-white mb-8">
                <Mic className="w-16 h-16 mx-auto mb-4" />
                <h3 className="text-xl font-bold mb-2">Story de Áudio</h3>
                <p className="text-white/80">Grave até 30 segundos</p>
              </div>

              {!preview ? (
                <div className="text-center">
                  <button
                    onClick={isRecording ? stopAudioRecording : startAudioRecording}
                    className={`p-6 rounded-full transition-all ${
                      isRecording 
                        ? 'bg-red-500 hover:bg-red-600 animate-pulse' 
                        : 'bg-white/20 hover:bg-white/30'
                    }`}
                  >
                    {isRecording ? (
                      <Square className="w-8 h-8 text-white" />
                    ) : (
                      <Mic className="w-8 h-8 text-white" />
                    )}
                  </button>
                  
                  {isRecording && (
                    <div className="mt-4 text-white text-lg font-bold">
                      {Math.floor(recordingTime / 60)}:{(recordingTime % 60).toString().padStart(2, '0')}
                    </div>
                  )}
                </div>
              ) : (
                <div className="text-center">
                  <div className="mb-4">
                    <div className="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4">
                      <Mic className="w-10 h-10 text-white" />
                    </div>
                    <p className="text-white">Áudio gravado: {recordingTime}s</p>
                  </div>
                  
                  <div className="flex space-x-4">
                    <button
                      onClick={isPlaying ? pauseAudio : playAudio}
                      className="p-3 bg-white/20 rounded-full hover:bg-white/30 transition-colors"
                    >
                      {isPlaying ? (
                        <Pause className="w-6 h-6 text-white" />
                      ) : (
                        <Play className="w-6 h-6 text-white" />
                      )}
                    </button>
                    
                    <button
                      onClick={() => {
                        setPreview(null);
                        setFile(null);
                      }}
                      className="p-3 bg-white/20 rounded-full hover:bg-white/30 transition-colors"
                    >
                      <RotateCcw className="w-6 h-6 text-white" />
                    </button>
                  </div>

                  <audio
                    ref={audioRef}
                    src={preview || ''}
                    onEnded={() => setIsPlaying(false)}
                    className="hidden"
                  />
                </div>
              )}
            </div>
          ) : storyType === 'text' ? (
            <div className="w-full h-full relative" style={{ backgroundColor }}>
              <div className="absolute inset-0 flex items-center justify-center p-8">
                <textarea
                  value={text}
                  onChange={(e) => setText(e.target.value)}
                  placeholder="Digite seu texto aqui..."
                  className="w-full h-32 bg-transparent text-center resize-none border-none outline-none text-2xl font-bold"
                  style={{ color: textColor }}
                  maxLength={200}
                />
              </div>

              {/* Paleta de cores */}
              <div className="absolute bottom-32 left-0 right-0 p-4">
                <div className="mb-4">
                  <p className="text-white/90 text-sm mb-2 text-center">Cor do fundo:</p>
                  <div className="flex justify-center space-x-2">
                    {backgroundColors.map((color) => (
                      <button
                        key={color}
                        onClick={() => setBackgroundColor(color)}
                        className={`w-8 h-8 rounded-full border-2 ${
                          backgroundColor === color ? 'border-white' : 'border-transparent'
                        }`}
                        style={{ backgroundColor: color }}
                      />
                    ))}
                  </div>
                </div>
                
                <div>
                  <p className="text-white/90 text-sm mb-2 text-center">Cor do texto:</p>
                  <div className="flex justify-center space-x-2">
                    {textColors.map((color) => (
                      <button
                        key={color}
                        onClick={() => setTextColor(color)}
                        className={`w-6 h-6 rounded-full border-2 ${
                          textColor === color ? 'border-white' : 'border-gray-400'
                        }`}
                        style={{ backgroundColor: color }}
                      />
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ) : storyType === 'upload' ? (
            <div className="w-full h-full bg-gray-900 flex flex-col items-center justify-center p-8">
              {!preview ? (
                <div className="text-center text-white">
                  <Upload className="w-16 h-16 mx-auto mb-4" />
                  <h3 className="text-xl font-bold mb-4">Upload de Arquivo</h3>
                  <button
                    onClick={() => fileInputRef.current?.click()}
                    className="px-6 py-3 bg-velvet-pink-600 text-white rounded-lg hover:bg-velvet-pink-700 transition-colors"
                  >
                    Escolher Arquivo
                  </button>
                  <p className="text-gray-400 text-sm mt-2">
                    Imagens até 15MB ou vídeos até 50MB
                  </p>
                </div>
              ) : (
                <div className="w-full h-full relative">
                  {file?.type.startsWith('video/') ? (
                    <video
                      ref={videoRef}
                      src={preview}
                      controls
                      className="w-full h-full object-cover"
                    />
                  ) : (
                    <img
                      src={preview}
                      alt="Preview"
                      className="w-full h-full object-cover"
                    />
                  )}
                </div>
              )}
            </div>
          ) : null}
        </div>

        {/* Barra lateral de tipos de story */}
        <div className="absolute right-4 top-1/2 transform -translate-y-1/2 z-20">
          <div className="flex flex-col space-y-4">
            {storyTypes.map((type) => (
              <button
                key={type.type}
                onClick={() => {
                  setStoryType(type.type);
                  setPreview(null);
                  setFile(null);
                  
                  if (type.type === 'camera' || type.type === 'video') {
                    startCamera();
                  } else {
                    stopCamera();
                  }
                }}
                className={`p-3 rounded-full transition-all ${
                  storyType === type.type
                    ? 'bg-velvet-pink-600 text-white'
                    : 'bg-black/50 text-white/70 hover:bg-black/70'
                }`}
                title={type.label}
              >
                {type.icon}
              </button>
            ))}
          </div>
        </div>

        {/* Botões de ação */}
        {(preview || file || (storyType === 'text' && text.trim())) && (
          <div className="absolute bottom-8 left-0 right-0 px-6 z-20">
            <div className="flex space-x-4">
              <button
                onClick={() => {
                  setPreview(null);
                  setFile(null);
                  setText('');
                  setLinkUrl('');
                  setLinkTitle('');
                  setLinkDescription('');
                  if (storyType === 'camera' || storyType === 'video') {
                    startCamera();
                  }
                }}
                className="flex-1 py-3 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors"
              >
                Refazer
              </button>
              
              <button
                onClick={() => setCurrentStep('info')}
                className="flex-1 py-3 bg-velvet-pink-600 text-white rounded-lg hover:bg-velvet-pink-700 transition-colors"
              >
                Postar Story
              </button>
            </div>
          </div>
        )}

        {/* Hidden elements */}
        <input
          ref={fileInputRef}
          type="file"
          accept="image/*,video/*"
          onChange={handleFileSelect}
          className="hidden"
        />
        
        <canvas ref={canvasRef} className="hidden" />
      </div>

    </div>
  );

};

export default CreateStoryModal; 