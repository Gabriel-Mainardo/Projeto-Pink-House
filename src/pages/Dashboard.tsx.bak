                  ...prev,
                  professionalName: data.display_name || data.name || prev.professionalName,
                  age: data.age?.toString() || prev.age,
                  city: data.location?.split(' - ')[0] || prev.city,
                  neighborhood: data.location?.split(' - ')[1] || prev.neighborhood,
                  oneHour: data.priceperhour || prev.oneHour,
                  thirtyMinutes: data.thirty_minutes || prev.thirtyMinutes,
                  pernoite: data.pernoite || prev.pernoite,
                  profilePhoto: data.image || prev.profilePhoto,
                  coverPhoto: data.cover_photo || prev.coverPhoto,
                  description: data.description || prev.description,
                  phone: data.phone || prev.phone,
                  photos: data.gallery || prev.photos,
                  videos: data.videos || prev.videos,
                  audioUrl: data.audio_url || prev.audioUrl,
                  specialties: data.tags || prev.specialties,
                  hasOwnPlace: data.hasownlocation || prev.hasOwnPlace,
                  acceptsClientPlace: data.acceptsclientlocation || prev.acceptsClientPlace,
                  acceptsMotel: data.acceptsmotel || prev.acceptsMotel,
