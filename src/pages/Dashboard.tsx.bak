                  Foto de capa
                </span>
              </div>

              <div className="flex items-center space-x-2 text-sm">
                {profileData.photos.length >= 5 ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.photos.length >= 5 ? 'text-gray-700' : 'text-gray-400'}>
                  Galeria com 5+ fotos ({profileData.photos.length}/5)
                </span>
              </div>

              <div className="flex items-center space-x-2 text-sm">
                {profileData.videos.length > 0 ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.videos.length > 0 ? 'text-gray-700' : 'text-gray-400'}>
                  Vídeo de apresentação
                </span>
              </div>

              <div className="flex items-center space-x-2 text-sm">
                {profileData.audioUrl ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.audioUrl ? 'text-gray-700' : 'text-gray-400'}>
                  Áudio de apresentação
                </span>
              </div>

              {/* Descrição */}
              <div className="flex items-center space-x-2 text-sm">
                {profileData.description.length >= 100 ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.description.length >= 100 ? 'text-gray-700' : 'text-gray-400'}>
                  Descrição completa ({profileData.description.length}/100 caracteres)
                </span>
              </div>

              {/* Valores */}
              <div className="flex items-center space-x-2 text-sm">
                {profileData.oneHour ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.oneHour ? 'text-gray-700' : 'text-gray-400'}>
                  Valor por 1 hora
                </span>
              </div>

              <div className="flex items-center space-x-2 text-sm">
                {profileData.thirtyMinutes ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.thirtyMinutes ? 'text-gray-700' : 'text-gray-400'}>
                  Valor por 30 minutos
                </span>
              </div>

              {/* Especialidades e atendimento */}
              <div className="flex items-center space-x-2 text-sm">
                {profileData.specialties.length > 0 ? (
