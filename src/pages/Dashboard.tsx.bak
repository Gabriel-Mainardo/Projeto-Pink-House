                )}
                <span className={profileData.specialties.length > 0 ? 'text-gray-700' : 'text-gray-400'}>
                  Especialidades selecionadas ({profileData.specialties.length})
                </span>
              </div>

              <div className="flex items-center space-x-2 text-sm">
                {profileData.hasOwnPlace || profileData.acceptsClientPlace || profileData.acceptsMotel ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.hasOwnPlace || profileData.acceptsClientPlace || profileData.acceptsMotel ? 'text-gray-700' : 'text-gray-400'}>
                  Tipos de atendimento
                </span>
              </div>

              <div className="flex items-center space-x-2 text-sm">
                {profileData.workingHours ? (
                  <CheckCircle className="w-4 h-4 text-green-500" />
                ) : (
                  <X className="w-4 h-4 text-gray-400" />
                )}
                <span className={profileData.workingHours ? 'text-gray-700' : 'text-gray-400'}>
                  Horário de atendimento
                </span>
              </div>
            </div>
          </div>

          {/* Painel de Estatísticas - Cards principais */}
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
            {/* Card 1: Visualizações */}
