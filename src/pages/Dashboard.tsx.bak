                            <div className="col-span-1 md:col-span-2">
                              <p className="text-sm font-semibold text-gray-700 mb-1">Cidades vizinhas que atendo</p>
                              <p className="text-sm text-gray-600">{profileData.location.cidadesVizinhas}</p>
                            </div>
                          </div>
                        </div>
                      </div>

                    </div>
                  </div>

                </div>
              )}

            </div>
          </div>

        </div>
      </main>

      <Footer />

      {/* Tutorial Interativo para Novos Usuários */}
      {showTutorial && (
        <>
          {/* Overlay escuro */}
          <div className="fixed inset-0 bg-black bg-opacity-60 z-[60] transition-opacity"></div>

          {/* Caixinha de Tutorial Flutuante */}
          <div className="fixed z-[70] transition-all duration-300"
            style={
              tutorialStep === 0 ? { top: '50%', left: '50%', transform: 'translate(-50%, -50%)' } :
              tutorialStep === 1 ? { top: '180px', left: '50%', transform: 'translateX(-50%)', maxWidth: '500px' } :
              tutorialStep === 2 ? { top: '320px', left: '20px', maxWidth: '400px' } :
              tutorialStep === 3 ? { bottom: '120px', left: '50%', transform: 'translateX(-50%)', maxWidth: '450px' } :
              { top: '50%', left: '50%', transform: 'translate(-50%, -50%)' }
            }
          >
            <div className="bg-white rounded-2xl shadow-2xl p-6 max-w-md mx-4 border-2 border-velvet-pink-300">

              {/* Passo 0: Boas-vindas */}
              {tutorialStep === 0 && (
                <div className="text-center">
                  <div className="w-20 h-20 bg-gradient-to-br from-velvet-pink-400 to-velvet-pink-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
                    <span className="text-4xl">👋</span>
                  </div>
                  <h3 className="text-2xl font-bold text-gray-800 mb-3">
                    Bem-vinda ao seu Dashboard!
                  </h3>
                  <p className="text-gray-600 mb-6 leading-relaxed">
                    Olá, {profileData.professionalName}! Este é o seu painel de controle.
                    Vamos te mostrar rapidinho como funciona tudo por aqui!
                  </p>
                  <button
                    onClick={() => setTutorialStep(1)}
                    className="w-full bg-gradient-to-r from-velvet-pink-600 to-velvet-pink-700 text-white py-3 px-6 rounded-xl font-semibold hover:from-velvet-pink-700 hover:to-velvet-pink-800 transition-all shadow-md"
                  >
                    Começar Tour 🚀
                  </button>
                  <button
                    onClick={() => setShowTutorial(false)}
                    className="w-full mt-3 text-gray-500 hover:text-gray-700 text-sm"
                  >
                    Pular tutorial
                  </button>
                </div>
              )}

              {/* Passo 1: Sistema de Verificação */}
              {tutorialStep === 1 && (
                <div>
                  <div className="flex items-center space-x-3 mb-4">
                    <div className="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                      <CheckCircle className="w-6 h-6 text-purple-600" />
                    </div>
                    <h3 className="text-xl font-bold text-gray-800">
                      Complete seu Perfil
                    </h3>
                  </div>
                  <p className="text-gray-600 mb-4 leading-relaxed">
                    Esta barra mostra o quanto você já preencheu do seu perfil.
                    <strong className="text-velvet-pink-600"> Quanto mais completo, mais visualizações você recebe!</strong>
                    💎 Clientes preferem perfis com fotos, vídeos e descrições detalhadas.
                  </p>
                  <div className="flex items-center space-x-2">
                    <button
                      onClick={() => setTutorialStep(2)}
                      className="flex-1 bg-gradient-to-r from-velvet-pink-600 to-velvet-pink-700 text-white py-2.5 px-4 rounded-lg font-medium hover:from-velvet-pink-700 hover:to-velvet-pink-800 transition-all"
                    >
                      Próximo
                    </button>
                    <button
                      onClick={() => setShowTutorial(false)}
                      className="px-4 py-2.5 text-gray-600 hover:text-gray-800 text-sm"
                    >
                      Pular
                    </button>
                  </div>
                  <div className="mt-4 text-center">
                    <span className="text-xs text-gray-400">Passo 1 de 3</span>
                  </div>
                </div>
              )}

              {/* Passo 2: Estatísticas */}
              {tutorialStep === 2 && (
                <div>
                  <div className="flex items-center space-x-3 mb-4">
                    <div className="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                      <BarChart3 className="w-6 h-6 text-blue-600" />
                    </div>
                    <h3 className="text-xl font-bold text-gray-800">
                      Acompanhe suas Estatísticas
                    </h3>
                  </div>
                  <p className="text-gray-600 mb-4 leading-relaxed">
                    Aqui você vê <strong className="text-blue-600">quantas pessoas visualizaram seu perfil</strong>,
                    quantos clicaram no WhatsApp e quantos te adicionaram aos favoritos.
                    Use essas informações para melhorar seu perfil! 📊
                  </p>
                  <div className="flex items-center space-x-2">
                    <button
                      onClick={() => setTutorialStep(3)}
                      className="flex-1 bg-gradient-to-r from-velvet-pink-600 to-velvet-pink-700 text-white py-2.5 px-4 rounded-lg font-medium hover:from-velvet-pink-700 hover:to-velvet-pink-800 transition-all"
                    >
                      Próximo
                    </button>
                    <button
                      onClick={() => setShowTutorial(false)}
                      className="px-4 py-2.5 text-gray-600 hover:text-gray-800 text-sm"
                    >
                      Pular
                    </button>
                  </div>
                  <div className="mt-4 text-center">
                    <span className="text-xs text-gray-400">Passo 2 de 3</span>
                  </div>
                </div>
              )}

              {/* Passo 3: Abas de Navegação */}
              {tutorialStep === 3 && (
                <div>
                  <div className="flex items-center space-x-3 mb-4">
                    <div className="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                      <User className="w-6 h-6 text-green-600" />
                    </div>
                    <h3 className="text-xl font-bold text-gray-800">
                      Navegue pelas Abas
                    </h3>
                  </div>
                  <p className="text-gray-600 mb-4 leading-relaxed">
                    Use as abas abaixo para: <br/>
                    • <strong className="text-velvet-pink-600">Meu Perfil:</strong> Editar informações, fotos e vídeos <br/>
                    • <strong className="text-blue-600">Estatísticas:</strong> Ver gráficos de visualizações <br/>
                    • <strong className="text-purple-600">Galeria:</strong> Gerenciar suas fotos e vídeos
                  </p>
                  <button
                    onClick={() => setShowTutorial(false)}
                    className="w-full bg-gradient-to-r from-green-600 to-green-700 text-white py-3 px-6 rounded-xl font-semibold hover:from-green-700 hover:to-green-800 transition-all shadow-md"
                  >
                    Entendi! Vamos começar ✨
                  </button>
                  <div className="mt-4 text-center">
                    <span className="text-xs text-gray-400">Passo 3 de 3</span>
                  </div>
                </div>
              )}

            </div>

            {/* Seta apontando (apenas nos passos 1, 2 e 3) */}
            {tutorialStep > 0 && (
              <div className="absolute"
                style={
                  tutorialStep === 1 ? { top: '-12px', left: '50%', transform: 'translateX(-50%)' } :
                  tutorialStep === 2 ? { top: '30%', left: '-12px' } :
                  tutorialStep === 3 ? { bottom: '-12px', left: '50%', transform: 'translateX(-50%)' } :
                  {}
                }
              >
                <div className="w-6 h-6 bg-white border-2 border-velvet-pink-300 transform rotate-45"
                  style={
                    tutorialStep === 1 ? { borderBottom: 'none', borderRight: 'none' } :
                    tutorialStep === 2 ? { borderTop: 'none', borderRight: 'none' } :
                    tutorialStep === 3 ? { borderTop: 'none', borderLeft: 'none' } :
                    {}
                  }
                ></div>
              </div>
            )}
          </div>
        </>
      )}
    </div>
  );
};

export default Dashboard;
