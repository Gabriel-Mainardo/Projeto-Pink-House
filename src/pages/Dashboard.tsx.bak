import { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import Header from '../components/Header';
import Footer from '../components/Footer';
import { User, Settings, Eye, Edit, Camera, Heart, MapPin, DollarSign, Phone, BarChart3, Bell, Crown, Zap, Upload, CheckCircle, Plus, Trash, X, EyeOff, Power, Volume2, Play } from 'lucide-react';
import { supabase } from '../lib/supabase';

const Dashboard = () => {
  const navigate = useNavigate();
  const [user, setUser] = useState<any>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [activeTab, setActiveTab] = useState('perfil');
  const [cadastroData, setCadastroData] = useState<any>(null);
  const [showTutorial, setShowTutorial] = useState(false);
  const [tutorialStep, setTutorialStep] = useState(0);

  const [profileData, setProfileData] = useState({
    professionalName: 'Isabela Santos',
    age: '25',
    city: 'Recife',
    neighborhood: 'Boa Viagem',
    oneHour: '800',
    thirtyMinutes: '500',
    fifteenMinutes: '300',
    pernoite: '2000',
    viagem: '5000',
    profilePhoto: '',
    coverPhoto: '',
    description: 'Olá! Sou Isabela, uma acompanhante de luxo que preza pela discrição, elegância e qualidade no atendimento. Com 25 anos, ofereço momentos únicos e inesquecíveis para cavalheiros que buscam companhia refinada.',
    isPublic: true,
    isVisible: true,
    phone: '',
    photos: [] as string[],
    videos: [] as string[],
    audioUrl: '',
    specialties: [] as string[],
    hasOwnPlace: false,
    acceptsClientPlace: false,
    acceptsMotel: false,
    workingHours: '',
    characteristics: {
      gender: 'Mulher Cisgênero',
      genitalia: 'Possui vagina',
      sexualPreference: 'Bissexual',
      weight: '58 kg',
      height: '1,68 m',
      ethnicity: 'Branca',
      eyeColor: 'Castanhos',
      hairStyle: 'Loira',
      hairLength: 'Longo',
      shoeSize: '37',
      silicone: 'Sim',
      tattoos: 'Sim, discreta',
      piercings: 'Não',
      smoker: 'Não',
      languages: 'Português e Inglês'
    },
    servicesOffered: [
      'Beijo na boca',
      'Oral com preservativo',
      'Oral sem preservativo',
      'Massagem relaxante',
      'Inversão',
      'Acompanhamento em eventos',
      'Jantar romântico',
      'Pernoite',
      'Viagens',
      'Finalização no corpo'
    ],
    servicesNotOffered: [
      'Anal',
      'BDSM',
      'Golden shower',
      'Sexo sem preservativo'
    ],
    location: {
      locaisAtendo: 'Local próprio, Hotéis, Motéis, Eventos',
      minhaLocalizacao: 'Recife - Boa Viagem',
      comodidades: 'Ar condicionado, Banheiro privativo, Estacionamento, Wi-Fi',
