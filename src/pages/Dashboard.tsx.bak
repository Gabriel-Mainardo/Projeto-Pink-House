                  width: `${(() => {
                    const items = [
                      { name: 'Nome profissional', completed: !!profileData.professionalName },
                      { name: 'Foto de perfil', completed: !!profileData.profilePhoto },
                      { name: 'Foto de capa', completed: !!profileData.coverPhoto },
                      { name: 'Galeria com 5+ fotos', completed: profileData.photos.length >= 5 },
                      { name: 'Vídeo de apresentação', completed: profileData.videos.length > 0 },
                      { name: 'Áudio de apresentação', completed: !!profileData.audioUrl },
                      { name: 'Descrição completa (100+ caracteres)', completed: profileData.description.length >= 100 },
                      { name: 'Idade informada', completed: !!profileData.age },
                      { name: 'Cidade e bairro', completed: !!profileData.city && !!profileData.neighborhood },
                      { name: 'Telefone/WhatsApp', completed: !!profileData.phone },
                      { name: 'Valor por 1 hora', completed: !!profileData.oneHour },
                      { name: 'Valor por 30 minutos', completed: !!profileData.thirtyMinutes },
                      { name: 'Especialidades selecionadas', completed: profileData.specialties.length > 0 },
                      { name: 'Tipos de atendimento', completed: profileData.hasOwnPlace || profileData.acceptsClientPlace || profileData.acceptsMotel },
                      { name: 'Horário de atendimento', completed: !!profileData.workingHours }
                    ];
                    const completed = items.filter(i => i.completed).length;
                    return Math.round((completed / items.length) * 100);
                  })()}%`,
                  background: 'linear-gradient(to right, #ef4444 0%, #f97316 25%, #fbbf24 50%, #84cc16 75%, #22c55e 100%)'
                }}
              />
              <div className="absolute inset-0 flex items-center justify-center">
                <span className="text-sm font-bold text-gray-700">
                  {(() => {
                    const items = [
