  useEffect(() => {
    const checkAuthAndLoadData = async () => {
      setIsLoading(true);
      const storedUser = localStorage.getItem('user');

      if (storedUser) {
        try {
          const parsedUser = JSON.parse(storedUser);
          if (parsedUser.isLoggedIn) {
            setUser(parsedUser);

            // Verificar se é primeira vez no dashboard
            const hasSeenTutorial = localStorage.getItem('hasSeenDashboardTutorial');
            if (!hasSeenTutorial && parsedUser.type === 'companion') {
              setShowTutorial(true);
              localStorage.setItem('hasSeenDashboardTutorial', 'true');
            }

            // Se for cadastro pendente, buscar dados do Supabase
            if (parsedUser.isPending && parsedUser.email) {
              const { data, error } = await supabase
                .from('cadastros_pendentes')
                .select('*')
                .eq('email', parsedUser.email)
                .single();

              if (error) {
                console.error('Erro ao buscar dados do cadastro:', error);
              } else if (data) {
                setCadastroData(data);
                // Atualizar profileData com os dados do cadastro
                setProfileData(prev => ({
                  ...prev,
                  professionalName: data.name || prev.professionalName,
                  age: data.age?.toString() || prev.age,
                  city: data.location?.split(' - ')[0] || prev.city,
                  neighborhood: data.location?.split(' - ')[1] || prev.neighborhood,
                  oneHour: data.priceperhour || prev.oneHour,
                  profilePhoto: data.image || prev.profilePhoto,
                  description: data.description || prev.description,
                }));
              }
            } else if (!parsedUser.isPending && parsedUser.email) {
              // Se NÃO for pendente, buscar dados da tabela acompanhantes (perfil aprovado)
              const { data, error } = await supabase
                .from('acompanhantes')
                .select('*')
                .eq('email', parsedUser.email)
                .single();

