            </div>
            <p className="text-sm text-gray-600 mb-4">Complete todos os itens para aumentar sua visibilidade e atrair mais clientes</p>

            {/* Checklist completa */}
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {/* Informações básicas */}
